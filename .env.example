## Multi-Tenancy ##
# All configuration — databases, AOS, payments, mail, mattermost, OAuth apps,
# web push, browser variables and the deployment-wide "$global" section — lives
# in ONE JSON document, never in the environment. See:
#   - tenants.config.example.json  (the shape; single-tenant is one entry "d")
#   - tenants.config.schema.json   ($schema reference for editor validation)
# Generate a starter document from an existing .env with:
#   pnpm tenants:migrate
MULTI_TENANCY=true

# Path to the document (preferred — source it from a secret mount; it holds
# every tenant's db / auth / payment secrets and the better-auth secret):
TENANTS_CONFIG_FILE=tenants.config.json
# ...or the same JSON inline (used only when TENANTS_CONFIG_FILE is unset):
# TENANTS_CONFIG=

## Build-time ##
# The ONLY browser variable still read from the environment: it is inlined into
# the client bundle at build time, so changing it requires rebuilding the app.
# Empty for a root deployment, or a subpath like '/portal'.
NEXT_PUBLIC_BASE_PATH=
