{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Goovee tenants configuration",
  "description": "Maps each Goovee tenant id (the URL path segment, letters only) to its configuration. Used via TENANTS_CONFIG_FILE or TENANTS_CONFIG when MULTI_TENANCY=true. Every section other than db/aos is optional — a missing section falls back to the process-level env vars.",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    }
  },
  "propertyNames": {
    "pattern": "^(\\$schema|[a-zA-Z]+)$"
  },
  "additionalProperties": {
    "$ref": "#/$defs/tenantConfig"
  },
  "$defs": {
    "tenantConfig": {
      "type": "object",
      "required": ["db", "aos"],
      "additionalProperties": false,
      "properties": {
        "db": {
          "type": "object",
          "required": ["url"],
          "additionalProperties": false,
          "properties": {
            "url": {
              "type": "string",
              "description": "Postgres connection URL of this tenant's own database. Every tenant has its own database; isolation is per-database."
            }
          }
        },
        "aos": {
          "type": "object",
          "required": ["url", "auth"],
          "additionalProperties": false,
          "properties": {
            "url": {
              "type": "string",
              "description": "Base URL of the AOS instance, e.g. https://erp.example.com/axelor-erp. Unique per tenant in topology A (dedicated AOS); shared across tenants in topology B (AOS multi-tenancy)."
            },
            "aosTenantId": {
              "type": "string",
              "description": "AOS-side tenant id — independent of the Goovee tenant id. Set it when this tenant lives on a shared AOS instance with AOS multi-tenancy (topology B): every AOS call then carries X-Tenant-ID with this value. Leave unset for a dedicated AOS instance (topology A)."
            },
            "storage": {
              "type": "string",
              "description": "Per-tenant file storage path. Defaults to the process-level storage path (DATA_STORAGE)."
            },
            "auth": {
              "type": "object",
              "description": "AOS credentials: apiKey (AOS 9+, generated in AOS under Preferences → API Keys) or username/password basic auth. apiKey wins when both are set.",
              "anyOf": [
                {"required": ["apiKey"]},
                {"required": ["username", "password"]}
              ],
              "additionalProperties": false,
              "properties": {
                "apiKey": {
                  "type": "string"
                },
                "username": {
                  "type": "string"
                },
                "password": {
                  "type": "string"
                }
              }
            },
            "webhookSecret": {
              "type": "string",
              "description": "Secret AOS uses to sign notification webhooks for this tenant (the NOTIFICATION_WEBHOOK_SECRET equivalent)."
            }
          }
        },
        "payments": {
          "type": "object",
          "description": "Per-tenant merchant accounts. Each provider falls back to the corresponding process env vars when omitted.",
          "additionalProperties": false,
          "properties": {
            "paypal": {
              "type": "object",
              "required": ["clientId", "clientSecret"],
              "additionalProperties": false,
              "properties": {
                "clientId": {"type": "string"},
                "clientSecret": {"type": "string"},
                "live": {
                  "type": "boolean",
                  "description": "true for live payments; defaults to sandbox (PAYPAL_LIVE equivalent)."
                }
              }
            },
            "stripe": {
              "type": "object",
              "required": ["clientSecret"],
              "additionalProperties": false,
              "properties": {
                "clientSecret": {"type": "string"},
                "webhookSecret": {
                  "type": "string",
                  "description": "Stripe webhook signing secret for this tenant's webhook endpoint."
                }
              }
            },
            "paybox": {
              "type": "object",
              "required": ["site", "rang", "identifiant", "secret", "paybox"],
              "additionalProperties": false,
              "properties": {
                "site": {"type": "string"},
                "rang": {"type": "string"},
                "identifiant": {"type": "string"},
                "secret": {"type": "string"},
                "paybox": {
                  "type": "string",
                  "description": "Paybox payment page base URL (PBX_PAYBOX equivalent)."
                },
                "backup1": {"type": "string"},
                "backup2": {"type": "string"}
              }
            },
            "up2pay": {
              "type": "object",
              "required": ["site", "rang", "identifiant", "secret", "paybox"],
              "additionalProperties": false,
              "properties": {
                "site": {"type": "string"},
                "rang": {"type": "string"},
                "identifiant": {"type": "string"},
                "secret": {"type": "string"},
                "paybox": {
                  "type": "string",
                  "description": "Up2Pay payment page base URL (UP2PAY_PAYBOX equivalent)."
                }
              }
            },
            "hubpisp": {
              "type": "object",
              "description": "Register this tenant's BPCE webhook URL with ?tenant=<tenantId> appended so the webhook can use the tenant's credentials before the tenant is known from the link data.",
              "required": [
                "tokenUrl",
                "apiUrl",
                "clientId",
                "clientSecret",
                "certFingerprint",
                "beneficiaryName",
                "iban"
              ],
              "additionalProperties": false,
              "properties": {
                "tokenUrl": {"type": "string"},
                "apiUrl": {"type": "string"},
                "clientId": {"type": "string"},
                "clientSecret": {"type": "string"},
                "certFingerprint": {"type": "string"},
                "beneficiaryName": {"type": "string"},
                "iban": {"type": "string"},
                "bic": {"type": "string"},
                "certsDir": {
                  "type": "string",
                  "description": "Directory holding this tenant's mTLS files client.crt and private-key.pem; defaults to certs/hubpisp."
                }
              }
            }
          }
        },
        "mail": {
          "type": "object",
          "description": "Per-tenant SMTP settings (MAIL_* equivalents).",
          "required": ["host", "port", "user", "password"],
          "additionalProperties": false,
          "properties": {
            "host": {"type": "string"},
            "port": {"type": "number"},
            "secure": {"type": "boolean"},
            "user": {"type": "string"},
            "password": {"type": "string"},
            "email": {
              "type": "string",
              "description": "From address; defaults to user (MAIL_EMAIL equivalent)."
            }
          }
        },
        "mattermost": {
          "type": "object",
          "description": "The Mattermost host is browser-facing — override it per tenant via publicEnv.GOOVEE_PUBLIC_MATTERMOST_HOST.",
          "additionalProperties": false,
          "properties": {
            "token": {
              "type": "string",
              "description": "Mattermost admin token (MATTERMOST_TOKEN equivalent)."
            },
            "createUsers": {
              "type": "boolean",
              "description": "Create Mattermost users on registration (CREATE_MATTERMOST_USERS equivalent)."
            }
          }
        },
        "oauth": {
          "type": "object",
          "description": "Per-tenant OAuth applications. Each provider is registered at startup under the provider id '<provider>-<tenantId>' — register the matching redirect URI (/api/auth/oauth2/callback/<provider>-<tenantId>) with the identity provider. Falls back to the global provider configured via env vars when omitted.",
          "additionalProperties": false,
          "properties": {
            "google": {
              "type": "object",
              "required": ["clientId", "clientSecret"],
              "additionalProperties": false,
              "properties": {
                "clientId": {"type": "string"},
                "clientSecret": {"type": "string"}
              }
            },
            "keycloak": {
              "type": "object",
              "required": ["clientId", "clientSecret", "issuer"],
              "additionalProperties": false,
              "properties": {
                "clientId": {"type": "string"},
                "clientSecret": {"type": "string"},
                "issuer": {
                  "type": "string",
                  "description": "Keycloak realm issuer URL (KEYCLOAK_ISSUER equivalent)."
                }
              }
            }
          }
        },
        "webPush": {
          "type": "object",
          "description": "Web-push signing identity (VAPID_PRIVATE_KEY/VAPID_SUBJECT equivalents); the public key lives in publicEnv.GOOVEE_PUBLIC_VAPID_PUBLIC_KEY. A browser holds one push subscription per service-worker registration, so per-tenant key pairs only take effect once tenants run on their own domains.",
          "required": ["privateKey", "subject"],
          "additionalProperties": false,
          "properties": {
            "privateKey": {"type": "string"},
            "subject": {
              "type": "string",
              "description": "mailto: address or https: URL identifying the sender to push services."
            }
          }
        },
        "publicEnv": {
          "type": "object",
          "description": "Tenant overrides for browser-exposed variables, merged over the env-derived values at load time.",
          "additionalProperties": false,
          "properties": {
            "GOOVEE_PUBLIC_HOST": {"type": "string"},
            "GOOVEE_PUBLIC_PAYPAL_CLIENT_ID": {"type": "string"},
            "GOOVEE_PUBLIC_LINKEDIN_URL": {"type": "string"},
            "GOOVEE_PUBLIC_TWITTER_URL": {"type": "string"},
            "GOOVEE_PUBLIC_INSTAGRAM_URL": {"type": "string"},
            "GOOVEE_PUBLIC_WHATSAPP_URL": {"type": "string"},
            "GOOVEE_PUBLIC_MATTERMOST_HOST": {"type": "string"},
            "GOOVEE_PUBLIC_VAPID_PUBLIC_KEY": {"type": "string"},
            "GOOVEE_PUBLIC_KEYCLOAK_OAUTH_BUTTON_LABEL": {"type": "string"},
            "GOOVEE_PUBLIC_KEYCLOAK_OAUTH_BUTTON_IMAGE": {"type": "string"}
          }
        }
      }
    }
  }
}
